DEEPGRAM_API_KEY=your-deepgram-key-here
# Deepgram model, pinned server-side (clients cannot request a pricier model).
DEEPGRAM_MODEL=nova-3
DATABASE_URL=sqlite://./data/voice-typer.db
BIND_ADDR=127.0.0.1:8090
# Set the Secure flag on the session cookie. Default true (prod is HTTPS).
# Set to false only for plain-http local dev on a non-localhost origin.
COOKIE_SECURE=true
ADMIN_BOOTSTRAP_EMAIL=you@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login
RUST_LOG=voice_typer_server=info,tower_http=info

# Stripe billing. Subscription gating is enabled only when all of these are set.
# Use test keys (sk_test_..., whsec_...) until you go live.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
# Public origin used to build Stripe redirect URLs (no trailing slash).
PUBLIC_BASE_URL=https://voice.codag.site

# Email (Resend). When RESEND_API_KEY is set, signup requires email verification
# before the free trial works. EMAIL_FROM must be on a domain verified in Resend;
# onboarding@resend.dev works for testing but only delivers to your own Resend
# account email, so verify your real domain before enabling this in production.
RESEND_API_KEY=
EMAIL_FROM=Voice Typer <onboarding@resend.dev>
